# bkit plugin local state (세션 런타임, 커밋 X)
/.bkit/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (절대 커밋 금지)
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example 은 커밋 (템플릿 용도)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# drizzle
/db/migrations/meta/

# OS
Thumbs.db

# editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.env*
# deploy/env/ 의 .env.{dev,prd}.example 도 템플릿이므로 예외 (위 .env* 룰 뒤에 와야 효과)
!deploy/env/.env.*.example

# Playwright E2E (test-results/auth state/report 모두 빌드 산출물)
/e2e/.auth/
/e2e/test-results/
/e2e/playwright-report/
/playwright/.cache/

# CB-05 지식팩 생성 산출물 (로컬)
oa-knowledge-*.md
oa-knowledge-*.jsonl

# 내부 데이터 덤프 (코드 미참조 · 로컬 작업 산출물)
docs/hotel-names-*.txt
