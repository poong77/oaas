# ============================================================
# 8_OA_AS DEV 환경 설정 (.env)
# 위치: /app/oaas/standalone/.env  (PM2 cwd /app/oaas/.env 심볼릭링크)
#
# DEV는 수동 관리 (SSM 미사용).
# 실제 값으로 채워서 EC2에 직접 업로드.
# ============================================================

# ---------- Next.js standalone ----------
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1

# ---------- Database (EC2 동일 노드 PostgreSQL 16 + pgvector) ----------
DATABASE_URL=postgres://oaas:CHANGE_ME@127.0.0.1:5432/oaas_dev?sslmode=disable

# ---------- Auth ----------
NEXTAUTH_SECRET=CHANGE_ME_dev_auth_secret
NEXTAUTH_URL=https://as-dev.oapms.co
OA_SSO_CLIENT_ID=
OA_SSO_CLIENT_SECRET=
OA_SSO_ISSUER=
AUTH_DEV_STUB=true

# ---------- 솔라피 SMS ----------
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# ---------- AWS (SES / S3) ----------
# S3는 EC2 IAM Role 사용 → 키 불필요.
# SES는 cross-account IAM User 키 사용.
AWS_REGION=ap-northeast-2
SES_REGION=ap-southeast-2
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=support-dev@oapms.com

# ---------- 첨부 파일 S3 ----------
S3_UPLOAD_BUCKET=oaas-uploads-dev
S3_UPLOAD_PREFIX=
S3_UPLOAD_PUBLIC_URL=https://files-dev.support.oapms.com

# ---------- Slack ----------
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_NEW=C...
SLACK_CHANNEL_URGENT=C...
SLACK_CHANNEL_DEV=C...

# ---------- 공개 베이스 URL ----------
PUBLIC_BASE_URL=https://as-dev.oapms.co

# ---------- oachat.ai ----------
OACHAT_EMBED_URL=

# ---------- Anthropic Claude ----------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---------- Cron 인증 (n8n에서 호출) ----------
CRON_SECRET=CHANGE_ME_dev_cron_secret

# ---------- OpenAI (시맨틱 검색 임베딩) ----------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
