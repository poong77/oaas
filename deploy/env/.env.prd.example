# ============================================================
# 8_OA_AS PRD 환경 설정 (.env)
# 위치: /app/oaas/standalone/.env  (PM2 cwd /app/oaas/.env 심볼릭링크)
#
# ⚠️ 이 파일은 예시. 실제 값은 AWS SSM Parameter Store (/oaas/prd/*)에 등록 후
#    deploy/generate-env.sh가 자동 생성한다.
#
# Parameter Store 등록 키 (모두 SecureString 권장):
#   /oaas/prd/DATABASE_URL
#   /oaas/prd/NEXTAUTH_SECRET
#   /oaas/prd/NEXTAUTH_URL
#   /oaas/prd/OA_SSO_CLIENT_ID, OA_SSO_CLIENT_SECRET, OA_SSO_ISSUER
#   /oaas/prd/SOLAPI_API_KEY, SOLAPI_API_SECRET, SOLAPI_SENDER
#   /oaas/prd/SES_ACCESS_KEY_ID, SES_SECRET_ACCESS_KEY  (SES 전용 IAM User)
#   /oaas/prd/SES_FROM_EMAIL
#   ※ S3는 EC2 IAM Role을 사용 → AWS_ACCESS_KEY_ID/SECRET 등록 금지.
#   /oaas/prd/S3_UPLOAD_BUCKET, S3_UPLOAD_PUBLIC_URL
#   /oaas/prd/SLACK_BOT_TOKEN, SLACK_CHANNEL_NEW, SLACK_CHANNEL_URGENT, SLACK_CHANNEL_DEV
#   /oaas/prd/PUBLIC_BASE_URL
#   /oaas/prd/OACHAT_EMBED_URL
#   /oaas/prd/ANTHROPIC_API_KEY
#   /oaas/prd/CRON_SECRET
#   /oaas/prd/OPENAI_API_KEY
# ============================================================

# ---------- Next.js standalone ----------
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1

# ---------- Database (RDS PostgreSQL 또는 EC2 동일 노드) ----------
# RDS PG 사용 시:    postgres://oaas:STRONG_PW@db.internal:5432/oaas_prd?sslmode=require
# EC2 동일 노드:    postgres://oaas:STRONG_PW@127.0.0.1:5432/oaas_prd?sslmode=disable
DATABASE_URL=postgres://oaas:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/oaas_prd?sslmode=disable

# ---------- Auth ----------
NEXTAUTH_SECRET=CHANGE_ME_prd_auth_secret_64chars_minimum
NEXTAUTH_URL=https://support.oapms.com
OA_SSO_CLIENT_ID=
OA_SSO_CLIENT_SECRET=
OA_SSO_ISSUER=
AUTH_DEV_STUB=false

# ---------- 솔라피 SMS ----------
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# ---------- AWS (SES / S3) ----------
# AWS_REGION/SES_REGION은 generate-env.sh 정적 블록에서 관리 (SSM 불필요).
#   S3 버킷=서울(ap-northeast-2), SES 도메인 인증=시드니(ap-southeast-2).
# S3는 EC2 IAM Role(oaas-IAM-role-ec2-prd) 사용 → 키 불필요.
# SES는 cross-account(oa-marketing 계정) IAM User 키 사용.
AWS_REGION=ap-northeast-2
SES_REGION=ap-southeast-2
SES_ACCESS_KEY_ID=AKIA...
SES_SECRET_ACCESS_KEY=...
SES_FROM_EMAIL=support@oapms.com

# ---------- 첨부 파일 S3 ----------
S3_UPLOAD_BUCKET=oaas-uploads-prd
S3_UPLOAD_PREFIX=
S3_UPLOAD_PUBLIC_URL=https://files.support.oapms.com

# ---------- Slack ----------
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_NEW=C...
SLACK_CHANNEL_URGENT=C...
SLACK_CHANNEL_DEV=C...

# ---------- 공개 베이스 URL ----------
PUBLIC_BASE_URL=https://support.oapms.com

# ---------- oachat.ai ----------
OACHAT_EMBED_URL=

# ---------- Anthropic Claude ----------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---------- Cron 인증 (n8n에서 호출) ----------
CRON_SECRET=CHANGE_ME_prd_cron_secret_64chars_minimum

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
