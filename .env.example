# =====================================================================
# 통합 AS 플랫폼 — 환경변수 템플릿
# 실제 값은 .env.local에 작성 (절대 커밋 금지)
# =====================================================================

# ---------- Database (Phase 0~) ----------
# Neon serverless PostgreSQL 연결 문자열 (sslmode=require 권장)
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx.aws.neon.tech/neondb?sslmode=require

# ---------- Auth / SSO (Phase 1) ----------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
OA_SSO_CLIENT_ID=
OA_SSO_CLIENT_SECRET=
OA_SSO_ISSUER=
# AUTH_DEV_STUB=true 일 때만 이메일+비번 로그인(시드 계정) 활성화
AUTH_DEV_STUB=true

# ---------- 솔라피 SMS (Phase 1) ----------
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# ---------- AWS SES / S3 (Phase 1, 5) ----------
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=support@oapms.com
S3_BUCKET=

# ---------- Slack Bot Token (Phase 5) ----------
# Bot Token 방식 (Webhook 대비 유연 — 채널별 URL 발급 불필요)
# 스코프: chat:write, chat:write.public, channels:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_NEW=C...        # #support_new (신규 티켓)
SLACK_CHANNEL_URGENT=C...     # #support_urgent (P1 긴급)
SLACK_CHANNEL_DEV=C...        # #support_escalation (Dev 에스컬레이션)

# ---------- 공개 베이스 URL (알림/이메일 절대 링크) ----------
# Slack '티켓 열기' 버튼, 초대/비번재설정 메일의 로그인 링크 등에 사용.
# 프로덕션(Vercel)에 반드시 https://support.oapms.com 으로 설정.
# 미설정 시 NEXTAUTH_URL → Vercel 자동 도메인(VERCEL_PROJECT_PRODUCTION_URL) → localhost 순 fallback.
PUBLIC_BASE_URL=http://localhost:3000

# ---------- oachat.ai (Phase 8) ----------
OACHAT_EMBED_URL=

# ---------- Anthropic Claude (knowledge-base-overhaul ~) ----------
# 아티클 작성 자동화 보조 (slug/summary/keywords/related/chatbot-meta 추출)
# 마케팅 플랫폼과 동일 키 사용. Vercel 등록은 `vercel env add ANTHROPIC_API_KEY`
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---------- Rate Limit (선택) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI (Phase 2 시맨틱 검색 임베딩)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
