# =====================================================================
# 통합 AS 플랫폼 — 환경변수 템플릿
# 실제 값은 .env.local에 작성 (절대 커밋 금지)
#
# 배포 모델: 자체 호스팅(EC2 + Nginx + PM2 + 자체 PostgreSQL). Vercel 사용 안 함.
# =====================================================================

# ---------- Database (PostgreSQL 16+ with pgvector) ----------
# 로컬:     postgres://oa:oa@localhost:5432/oa_as_dev
# EC2 내부: postgres://oa:secret@127.0.0.1:5432/oa_as_prd?sslmode=disable
# RDS:      postgres://oa:secret@db.internal:5432/oa_as_prd?sslmode=require
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/oa_as_dev

# ---------- Auth / SSO (Phase 1) ----------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
OA_SSO_CLIENT_ID=
OA_SSO_CLIENT_SECRET=
OA_SSO_ISSUER=
# AUTH_DEV_STUB=true 일 때만 이메일+비번 로그인(시드 계정) 활성화
AUTH_DEV_STUB=true

# ---------- 솔라피 SMS (Phase 1) ----------
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# ---------- AWS (SES / S3 업로드) ----------
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=support@oapms.com

# ---------- 첨부 파일 S3 (이전 Vercel Blob 대체) ----------
# S3_UPLOAD_BUCKET     : 업로드 대상 버킷 (예: oa-as-uploads-prd)
# S3_UPLOAD_PREFIX     : 키 prefix (선택, 환경 분리용 예: prd/8_OA_AS)
# S3_UPLOAD_PUBLIC_URL : 공개 도메인 (CloudFront 권장, 예: https://files.support.oapms.com)
#                        설정 시 응답 URL은 `{PUBLIC_URL}/{key}` 형식.
S3_UPLOAD_BUCKET=
S3_UPLOAD_PREFIX=
S3_UPLOAD_PUBLIC_URL=

# ---------- Slack Bot Token (Phase 5) ----------
# 스코프: chat:write, chat:write.public, channels:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_NEW=C...        # #support_new (신규 티켓)
SLACK_CHANNEL_URGENT=C...     # #support_urgent (P1 긴급)
SLACK_CHANNEL_DEV=C...        # #support_escalation (Dev 에스컬레이션)

# ---------- 공개 베이스 URL (알림/이메일 절대 링크) ----------
# Slack '티켓 열기' 버튼, 초대/비번재설정 메일의 로그인 링크 등에 사용.
# 프로덕션: https://support.oapms.com
# 미설정 시 NEXTAUTH_URL → localhost 순 fallback.
PUBLIC_BASE_URL=http://localhost:3000

# ---------- oachat.ai (Phase 8) ----------
OACHAT_EMBED_URL=

# ---------- Anthropic Claude (knowledge-base-overhaul ~) ----------
# 아티클 작성 자동화 보조 (slug/summary/keywords/related/chatbot-meta 추출)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---------- Cron 인증 (n8n에서 호출) ----------
# /api/cron/* 에서 Authorization: Bearer ${CRON_SECRET} 검증.
# n8n 워크플로우에서 동일 값을 헤더로 전송.
CRON_SECRET=

# ---------- Rate Limit (선택) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- OpenAI (Phase 2 시맨틱 검색 임베딩) ----------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
