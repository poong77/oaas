# =====================================================================
# 통합 AS 플랫폼 — 환경변수 템플릿
# 실제 값은 .env.local에 작성 (절대 커밋 금지)
# =====================================================================

# ---------- Database (Phase 0~) ----------
# Neon serverless PostgreSQL 연결 문자열 (sslmode=require 권장)
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx.aws.neon.tech/neondb?sslmode=require

# ---------- Auth / SSO (Phase 1) ----------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
OA_SSO_CLIENT_ID=
OA_SSO_CLIENT_SECRET=
OA_SSO_ISSUER=
# AUTH_DEV_STUB=true 일 때만 이메일+비번 로그인(시드 계정) 활성화
AUTH_DEV_STUB=true

# ---------- 솔라피 SMS (Phase 1) ----------
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# ---------- AWS SES / S3 (Phase 1, 5) ----------
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=support@oapms.com
S3_BUCKET=

# ---------- Slack Webhook (Phase 5) ----------
SLACK_WEBHOOK_NEW=
SLACK_WEBHOOK_URGENT=
SLACK_WEBHOOK_DEV=

# ---------- oachat.ai (Phase 8) ----------
OACHAT_EMBED_URL=

# ---------- Rate Limit (선택) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
